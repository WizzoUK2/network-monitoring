# UniFi Controller (Phase 2)
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=changeme
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

# ClickHouse
CLICKHOUSE_USER=netmon
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DB=netmon

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme
GF_INSTALL_PLUGINS=grafana-clickhouse-datasource

# Network Ports
SYSLOG_PORT=514
NETFLOW_PORT=2055

# InfluxDB (Phase 3)
INFLUXDB_USER=netmon
INFLUXDB_PASSWORD=changeme123
INFLUXDB_ORG=netmon
INFLUXDB_BUCKET=network
INFLUXDB_TOKEN=netmon-influx-token

# Alerting (Phase 3)
ANOMALY_DETECTION_ENABLED=false
ALERTMANAGER_URL=http://alertmanager:9093
