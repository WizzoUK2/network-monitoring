{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Syslog Event Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({source=~\".+\"} [$__interval]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events by Source Device",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (vendor) (count_over_time({source=~\".+\"} [$__range]))",
          "legendFormat": "{{vendor}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events by Severity",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({source=~\".+\"} [$__range]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events by Product",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (product) (count_over_time({source=~\".+\"} [$__range]))",
          "legendFormat": "{{product}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "UniFi CEF Events",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{source=~\"$source\"} | json | line_format \"{{.event_name}} src={{.src_ip}} dst={{.dst_ip}} {{.action}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Firewall Events (CEF)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{source=\"unifi_cef\"} |= \"Firewall\"",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["network", "syslog"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({source=~\".+\"}, source)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "source",
        "options": [],
        "query": "label_values({source=~\".+\"}, source)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Syslog Explorer",
  "uid": "netmon-syslog"
}
